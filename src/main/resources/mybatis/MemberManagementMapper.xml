<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="whitekim.self_developing.admin.mapper.MemberManagementMapper">
    <select id="selectMemberList" resultType="whitekim.self_developing.admin.model.MemberInfo">
        select
            m.
        id as user_id,
            m.username,
            m.at_created,
            m.latest_access_time
        from member m
        where
            m.permission = 0
    </select>

    <update id="deleteMember" parameterType="Long">
        update member
        set
            is_deleted = true,
            at_deleted = now()
        where
            user_id = #{userId}
    </update>
</mapper>
